# ============================================================
# WAREHOUSE MANAGEMENT SYSTEM — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git. Only commit .env.example.
# ============================================================

# --- Application ---
NODE_ENV=development         # Options: development | staging | production
APP_PORT=3000                # Port the NestJS server listens on

# --- PostgreSQL Database ---
DB_HOST=localhost            # Database server host
DB_PORT=5432                 # Default PostgreSQL port
DB_USERNAME=your_db_user     # PostgreSQL username
DB_PASSWORD=your_db_password # PostgreSQL password
DB_NAME=warehouse_db         # Database name

# --- TypeORM ---
# synchronize=true auto-creates tables from entities (DEV ONLY — NEVER use in production)
# In production, use migrations instead
DB_SYNCHRONIZE=true          # true = development | false = production
DB_LOGGING=true              # true = log all SQL queries (useful for debugging)
