{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "perf:smoke":     "k6 run k6/run-all.js -e TEST_TYPE=smoke",
    "perf:load":      "k6 run k6/run-all.js -e TEST_TYPE=load",
    "perf:stress":    "k6 run k6/run-all.js -e TEST_TYPE=stress",
    "perf:spike":     "k6 run k6/run-all.js -e TEST_TYPE=spike",
    "perf:auth":      "k6 run k6/scenarios/auth.perf.js -e TEST_TYPE=load",
    "perf:products":  "k6 run k6/scenarios/products.perf.js -e TEST_TYPE=load",
    "perf:inventory": "k6 run k6/scenarios/inventory.perf.js -e TEST_TYPE=load",
    "perf:orders":    "k6 run k6/scenarios/orders.perf.js -e TEST_TYPE=load",
    "perf:report":    "k6 run --out json=k6/reports/results.json k6/run-all.js -e TEST_TYPE=load",

    "smoke":              "k6 run k6/smoke-all.js",
    "smoke:auth":         "k6 run k6/smoke/auth.smoke.js",
    "smoke:products":     "k6 run k6/smoke/products.smoke.js",
    "smoke:inventory":    "k6 run k6/smoke/inventory.smoke.js",
    "smoke:orders":       "k6 run k6/smoke/orders.smoke.js",
    "smoke:report":       "k6 run --out json=k6/reports/smoke-all.json k6/smoke-all.js",

    "stress":             "k6 run k6/stress-all.js",
    "stress:auth":        "k6 run k6/stress/auth.stress.js",
    "stress:products":    "k6 run k6/stress/products.stress.js",
    "stress:inventory":   "k6 run k6/stress/inventory.stress.js",
    "stress:orders":      "k6 run k6/stress/orders.stress.js",
    "stress:report":      "k6 run --out json=k6/reports/stress-all.json k6/stress-all.js",
    "stress:csv":         "k6 run --out csv=k6/reports/stress-all.csv k6/stress-all.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
