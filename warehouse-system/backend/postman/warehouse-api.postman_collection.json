{
  "info": {
    "name": "Warehouse Management System API",
    "description": "Complete API collection for the Warehouse Management System backend.\n\nBase URL: http://localhost:3000/api\n\n## Authentication\nMost endpoints require a JWT Bearer token.\n1. Run **Auth / Register** to create an account.\n2. Run **Auth / Login** — the token is auto-saved to `{{accessToken}}`.\n3. All protected requests use `{{accessToken}}` automatically.\n\n## Environment\nImport `warehouse-api.postman_environment.json` to set up variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:3000/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "productId",   "value": "", "type": "string" },
    { "key": "orderId",     "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "description": "User registration, login, and profile endpoints.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Has user id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"qa-tester@warehouse.com\",\n  \"firstName\": \"QA\",\n  \"lastName\": \"Tester\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Has accessToken', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  console.log('Token saved:', body.accessToken.substring(0, 20) + '...');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"qa-tester@warehouse.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Invalid Credentials (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"qa-tester@warehouse.com\",\n  \"password\": \"WrongPassword\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Has email', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          }
        }
      ]
    },

    {
      "name": "Products",
      "description": "Product catalog management — CRUD operations.",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Has id and sku', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('sku');",
                  "  pm.collectionVariables.set('productId', body.id);",
                  "  console.log('productId saved:', body.id);",
                  "});"
