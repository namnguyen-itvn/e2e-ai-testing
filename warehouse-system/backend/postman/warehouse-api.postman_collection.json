            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"WH-PROD-001\",\n  \"name\": \"Duplicate SKU Test\",\n  \"price\": 10,\n  \"quantity\": 0,\n  \"unit\": \"pcs\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        }
      ]
